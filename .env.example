# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/woontegra_license?schema=public

# Server
PORT=4000

# Admin (used by seed)
ADMIN_EMAIL=admin@woontegra.com
ADMIN_PASSWORD=change-me-strong-password

# JWT
JWT_SECRET=change-me-jwt-secret-min-32-chars

# SMTP (optional - mail fails gracefully if not configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@woontegra.com

# Website integration
INTEGRATION_SECRET=change-me-integration-secret
